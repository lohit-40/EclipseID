# Your Midnight wallet seed phrase (24 words) or hex seed.
# You can get this from a wallet extension like Lace or Nightly configured for Preprod.
# WARNING: NEVER COMMIT your actual `.env.preprod` file.
SEED="insert your 24 word seed phrase here"

# The endpoint of the local proof server you are running via docker-compose
PROOF_SERVER_URL="http://127.0.0.1:6300"

# Preprod network endpoints
INDEXER_URL="https://indexer.preprod.midnight.network/api/v1/graphql"
NODE_URL="https://rpc.preprod.midnight.network"
